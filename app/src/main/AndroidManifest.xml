<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ========================= -->
    <!-- PERMISSION -->
    <!-- ========================= -->

    <!-- NOTIFIKASI -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- EXACT ALARM -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission
        android:name="android.permission.USE_EXACT_ALARM"/>

    <!-- GETAR -->
    <uses-permission
        android:name="android.permission.VIBRATE"/>

    <!-- BOOT COMPLETED -->
    <uses-permission
        android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ReminderTugasMahasiswa">

        <!-- ========================= -->
        <!-- SPLASH ACTIVITY -->
        <!-- ========================= -->

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.ReminderTugasMahasiswa">

            <intent-filter>

                <action
                    android:name="android.intent.action.MAIN"/>

                <category
                    android:name="android.intent.category.LAUNCHER"/>

            </intent-filter>

        </activity>

        <!-- ========================= -->
        <!-- MAIN ACTIVITY -->
        <!-- ========================= -->

        <activity
            android:name=".MainActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- ADD EDIT TASK -->
        <!-- ========================= -->

        <activity
            android:name=".AddEditTaskActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- TASK MANAGEMENT -->
        <!-- ========================= -->

        <activity
            android:name=".TaskManagementActivity"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- ALARM RECEIVER -->
        <!-- ========================= -->

        <receiver
            android:name=".receiver.AlarmReceiver"
            android:exported="false"/>

        <!-- ========================= -->
        <!-- STOP ALARM RECEIVER -->
        <!-- ========================= -->



        <!-- ========================= -->
        <!-- BOOT RECEIVER -->
        <!-- ========================= -->

        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">

            <intent-filter>

                <action
                    android:name=
                        "android.intent.action.BOOT_COMPLETED"/>

            </intent-filter>

        </receiver>

        <!-- ========================= -->
        <!-- WIDGET -->
        <!-- ========================= -->

        <receiver
            android:name=".widget.TaskWidget"
            android:exported="true">

            <intent-filter>

                <action
                    android:name=
                        "android.appwidget.action.APPWIDGET_UPDATE"/>

            </intent-filter>

            <meta-data
                android:name=
                    "android.appwidget.provider"

                android:resource=
                    "@xml/task_widget_info"/>

        </receiver>

        <!-- ========================= -->
        <!-- ALARM SERVICE -->
        <!-- ========================= -->

        <service
            android:name=".service.AlarmService"
            android:exported="false"/>

        <receiver
            android:name=".receiver.StopAlarmReceiver"
            android:exported="false"/>

    </application>

</manifest>